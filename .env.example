# Application settings
LAB_TRACKER_APP_NAME=lab-tracker
LAB_TRACKER_ENVIRONMENT=production
LAB_TRACKER_LOG_LEVEL=INFO
LAB_TRACKER_DATABASE_URL=postgresql+psycopg://lab_tracker:lab_tracker@postgres:5432/lab_tracker
LAB_TRACKER_NOTE_STORAGE_PATH=/app/data/note_storage
LAB_TRACKER_AUTH_SECRET_KEY=replace-with-a-strong-random-secret
LAB_TRACKER_AUTH_TOKEN_TTL_MINUTES=720
# Optional: one-time admin bootstrap for fresh deployments (only honored when users table is empty)
LAB_TRACKER_BOOTSTRAP_ADMIN_TOKEN=

# Postgres service settings for docker-compose
POSTGRES_DB=lab_tracker
POSTGRES_USER=lab_tracker
POSTGRES_PASSWORD=lab_tracker

# Optional migration retry settings used by docker-entrypoint.sh
MIGRATION_MAX_ATTEMPTS=30
MIGRATION_SLEEP_SECONDS=2

# Lab Tracker MCP service-client settings (do not commit real credentials)
LAB_TRACKER_MCP_BASE_URL=http://127.0.0.1:8000
LAB_TRACKER_MCP_USERNAME=
LAB_TRACKER_MCP_PASSWORD=
LAB_TRACKER_MCP_TIMEOUT_SECONDS=10

# Export-only Dolt mirror settings
LAB_TRACKER_DOLT_BIN=dolt
LAB_TRACKER_DOLT_MIRROR_PATH=.lab-tracker-dolt
