LAB_TRACKER_ENVIRONMENT=production
LAB_TRACKER_AUTH_SECRET_KEY=replace-with-a-long-random-secret
LAB_TRACKER_BOOTSTRAP_ADMIN_TOKEN=replace-with-one-time-bootstrap-token

POSTGRES_DB=lab_tracker
POSTGRES_USER=lab_tracker
POSTGRES_PASSWORD=replace-with-a-strong-db-password
LAB_TRACKER_DATABASE_URL=postgresql+psycopg://lab_tracker:replace-with-a-strong-db-password@postgres:5432/lab_tracker

LAB_TRACKER_FILE_STORAGE_PATH=/app/data/file_storage
LAB_TRACKER_NOTE_STORAGE_PATH=/app/data/note_storage
LAB_TRACKER_AUTH_TOKEN_TTL_MINUTES=720
